    {
      "parameters": {
        "jsCode": "const extractedData = $input.first().json;\nconst upload_date = $('Webhook').first().json.submittedAt;\nconst file_meta = $('Loop Over Items').first().json;\n\n// Parse Markdown\nif (!extractedData.pages && file_meta.mimetype.includes(\"octet\")) {\n return  {\n   json: {\n    pageContent: extractedData.data,\n    metadata: {\n      source: `${file_meta.filename}`,\n      originalBlobType: file_meta.mimetype,\n      blobType: \"text/markdown\",\n      uploadDate: upload_date,\n    }\n  }\n  }\n}\n\n// Parse OCR\nelse {\n  return extractedData.pages.map((page, i) => ({\n  json: {\n    pageContent: page.markdown.trim(),\n    metadata: {\n      source: `${file_meta.filename}`,\n      originalBlobType: file_meta.mimetype,\n      blobType: \"text/markdown\",\n      page: i + 1,\n      uploadDate: upload_date,\n      model: extractedData.model || \"\",\n      image:  {\n        imageData: page.images || \"\",\n        imageAnalysis: \"\"\n      }\n    }\n  }\n}));\n}\n"
      },
