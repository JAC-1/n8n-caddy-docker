        "html": "<style>\n.message-card {\n  max-width: 70%;\n  padding: 1.5rem 1.7rem;\n  border: 0.5px solid #A7C7E7; /* dark slate */\n  color: black;\n  border-radius: 12px; /* slightly cuter rounding */\n  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15); /* softer shadow for depth */\n  margin-bottom: 16px;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  line-height: 1.6;\n  position: relative;\n  transition: transform 0.15s ease;\n}\n\n.message-card:hover {\n  transform: translateY(-1px); /* subtle lift on hover */\n}\n.message-card h1,\n.message-card h2,\n.message-card h3,\n.message-card h4,\n.message-card h5,\n.message-card h6 {\n  margin-top: 1rem;\n  margin-bottom: 0.5rem;\n  font-weight: 600;\n}\n\n.message-card p {\n  margin-bottom: 0.75rem;\n  line-height: 1.6;\n}\n\n.message-card ul,\n.message-card ol {\n  margin-bottom: 0.75rem;\n  padding-left: 1.5rem;\n}\n\n.message-card li {\n  margin-bottom: 0.25rem;\n  text-decor\n}\n\n.message-card blockquote {\n  margin: 0.75rem 0;\n  padding: 0.5rem 1rem;\n  border-left: 4px solid #6b7280;\n  background: rgba(107, 114, 128, 0.1);\n  font-style: italic;\n}\n\n.message-card code {\n  background: rgba(0, 0, 0, 0.1);\n  padding: 0.125rem 0.25rem;\n  border-radius: 3px;\n  font-family: 'Monaco', 'Consolas', monospace;\n  font-size: 0.9em;\n}\n\n.message-card pre {\n  margin: 0.75rem 0;\n  padding: 0.75rem;\n  background: #1f2937;\n  border-radius: 6px;\n  overflow-x: auto;\n}\n\n.message-card pre code {\n  background: none;\n  padding: 0;\n  border-radius: 0;\n}\n.message-card ul {\n  list-style: none;\n  margin-bottom: 0.75rem;\n  padding-left: 0;\n}\n\n.message-card ul li {\n  position: relative;\n  padding-left: 1.25rem;\n}\n\n.message-card ul li::before {\n  content: \"▸\"; /* arrow bullet */\n  position: absolute;\n  left: 0;\n  color: #9ca3af; /* light gray */\n  font-weight: bold;\n}\n/* .message-card::before {\n  content: \"AI:\";\n  position: absolute;\n  top: 8px;\n  left: 12px;\n  font-size: 16px;\n  opacity: 0.7;\n} /* subtle chat icon */ */\n</style>\n\n<div class=\"message-card\" style=\"padding-left: 36px;\"> <!-- adjusted for icon space -->\n  {{$json.html}}\n</div>\n"
